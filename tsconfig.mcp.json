{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.mcp.tsbuildinfo",
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "types": ["node"],
    "skipLibCheck": true,
    "outDir": "dist-mcp",
    "rootDir": ".",
    "declaration": false,
    "sourceMap": false,

    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "erasableSyntaxOnly": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": [
    "mcp/**/*.ts",
    "src/lib/dates.ts",
    "src/lib/llm/systemPrompts.ts",
    "src/lib/markdown.ts",
    "src/lib/noteWrites.ts",
    "src/lib/notesCore.ts"
  ],
  "exclude": ["mcp/remoteServer.ts", "mcp/worker.ts"]
}
