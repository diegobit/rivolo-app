{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noEmit": true,
    "types": ["@cloudflare/workers-types"],
    "skipLibCheck": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true
  },
  "include": [
    "mcp/worker.ts",
    "mcp/remoteServer.ts",
    "mcp/readTools.ts",
    "mcp/writeTools.ts",
    "mcp/providerWriteErrors.ts",
    "mcp/providers/dropboxNotes.ts",
    "mcp/googleDriveNotesSource.ts",
    "functions/_lib/dropboxOAuth.ts",
    "functions/_lib/googleOAuth.ts",
    "functions/_lib/mcpAgentAccess.ts",
    "functions/_lib/mcpOAuth.ts",
    "functions/_lib/mcpPersonalTokens.ts",
    "functions/_lib/mcpWriteIdempotency.ts",
    "functions/_lib/providerProfiles.ts",
    "functions/_lib/tokenCookie.ts",
    "src/lib/dates.ts",
    "src/lib/llm/systemPrompts.ts",
    "src/lib/markdown.ts",
    "src/lib/mcpOAuthMetadata.ts",
    "src/lib/noteWrites.ts",
    "src/lib/notesCore.ts",
    "src/lib/writeOperationId.ts"
  ]
}
